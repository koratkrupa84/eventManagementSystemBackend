// controllers/requestController.js
const PrivateEventRequest = require('../models/PrivateEventRequest');
const User = require('../models/User');

// GET Approved Requests
exports.getApprovedRequests = async (req, res) => {
  try {
    // Find only approved requests
    const approvedRequests = await PrivateEventRequest.find({ status: 'approved' })
      .populate('client_id', 'name email')   // Populate client info
      .sort({ createdAt: -1 });

    res.status(200).json({
      success: true,
      data: approvedRequests
    });
  } catch (error) {
    console.error('Error fetching approved requests:', error);
    res.status(500).json({
      success: false,
      message: error.message
    });
  }
};